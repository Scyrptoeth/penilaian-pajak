---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Halaman Tidak Ditemukan" description="Halaman yang Anda cari tidak ditemukan.">
  <section class="mx-auto flex max-w-3xl flex-col items-center justify-center px-4 py-24 text-center sm:px-6 lg:px-8">
    <p class="font-mono text-6xl font-bold text-accent-400">404</p>
    <h1 class="mt-4 font-heading text-2xl font-bold tracking-tight text-neutral-800 dark:text-stone-100 sm:text-3xl">
      Halaman Tidak Ditemukan
    </h1>
    <p class="mt-3 text-neutral-500 dark:text-stone-400">
      Maaf, halaman yang Anda cari tidak ada atau telah dipindahkan.
    </p>

    <div class="mt-10 flex flex-col gap-3 sm:flex-row">
      <a
        href="/"
        class="inline-flex items-center justify-center gap-2 bg-neutral-800 px-6 py-3 font-heading text-sm font-semibold tracking-widest text-white uppercase transition-colors hover:bg-neutral-700 dark:bg-accent-400 dark:text-neutral-900 dark:hover:bg-accent-300 focus-visible:ring-2 focus-visible:ring-accent-400"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
          <path fill-rule="evenodd" d="M9.293 2.293a1 1 0 011.414 0l7 7A1 1 0 0117 11h-1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-3a1 1 0 00-1-1H9a1 1 0 00-1 1v3a1 1 0 01-1 1H5a1 1 0 01-1-1v-6H3a1 1 0 01-.707-1.707l7-7z" clip-rule="evenodd" />
        </svg>
        Beranda
      </a>
      <a
        href="/perpustakaan"
        class="inline-flex items-center justify-center gap-2 border-2 border-neutral-800 px-6 py-3 font-heading text-sm font-semibold tracking-widest text-neutral-800 uppercase transition-colors hover:bg-neutral-800 hover:text-white dark:border-accent-400 dark:text-accent-400 dark:hover:bg-accent-400 dark:hover:text-neutral-900 focus-visible:ring-2 focus-visible:ring-accent-400"
      >
        Perpustakaan
      </a>
      <a
        href="/pencarian"
        class="inline-flex items-center justify-center gap-2 border-2 border-neutral-800 px-6 py-3 font-heading text-sm font-semibold tracking-widest text-neutral-800 uppercase transition-colors hover:bg-neutral-800 hover:text-white dark:border-accent-400 dark:text-accent-400 dark:hover:bg-accent-400 dark:hover:text-neutral-900 focus-visible:ring-2 focus-visible:ring-accent-400"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
          <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
        </svg>
        Pencarian
      </a>
    </div>
  </section>
</BaseLayout>
