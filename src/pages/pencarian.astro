---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pencarian Peraturan" description="Cari peraturan penilaian pajak dengan pencarian full-text ke dalam isi pasal dan ayat.">
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <h1 class="font-heading text-3xl font-bold tracking-tight text-navy-800 dark:text-stone-100 sm:text-4xl">
        Pencarian Peraturan
      </h1>
      <p class="mt-3 text-navy-500 dark:text-stone-400">
        Cari kata kunci, frasa, atau kalimat di dalam isi peraturan. Hasil pencarian menampilkan potongan teks yang relevan.
      </p>
    </div>

    <!-- Pagefind search widget -->
    <div class="mt-8">
      <div id="search" class="min-h-[400px]"></div>
    </div>

    <!-- Usage tips -->
    <div class="mt-12 border-2 border-navy-100 p-6 dark:border-navy-800">
      <h2 class="font-heading text-lg font-semibold text-navy-800 dark:text-stone-100">Tips Pencarian</h2>
      <ul class="mt-4 space-y-2 text-sm text-navy-600 dark:text-stone-400">
        <li class="flex items-start gap-2">
          <span class="mt-0.5 inline-block h-1.5 w-1.5 shrink-0 bg-gold-400"></span>
          <span><strong class="text-navy-800 dark:text-stone-200">Kata kunci tunggal:</strong> <code class="font-mono text-gold-600 dark:text-gold-400">penilaian</code></span>
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-0.5 inline-block h-1.5 w-1.5 shrink-0 bg-gold-400"></span>
          <span><strong class="text-navy-800 dark:text-stone-200">Multi kata kunci:</strong> <code class="font-mono text-gold-600 dark:text-gold-400">klasifikasi panas bumi</code></span>
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-0.5 inline-block h-1.5 w-1.5 shrink-0 bg-gold-400"></span>
          <span><strong class="text-navy-800 dark:text-stone-200">Frasa persis:</strong> <code class="font-mono text-gold-600 dark:text-gold-400">"nilai jual objek pajak"</code></span>
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-0.5 inline-block h-1.5 w-1.5 shrink-0 bg-gold-400"></span>
          <span><strong class="text-navy-800 dark:text-stone-200">Nomor peraturan:</strong> <code class="font-mono text-gold-600 dark:text-gold-400">PMK-79</code></span>
        </li>
      </ul>
    </div>
  </section>

  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script is:inline>
    async function initPagefind() {
      try {
        const el = document.getElementById('search');
        if (!el) return;

        // Dynamic import is more reliable than external script tag
        await import('/pagefind/pagefind-ui.js');

        if (typeof PagefindUI === 'undefined') return;

        new PagefindUI({
          element: '#search',
          showSubResults: true,
          showImages: false,
          translations: {
            placeholder: 'Cari di dalam isi peraturan...',
            zero_results: 'Tidak ditemukan hasil untuk "[SEARCH_TERM]"',
            many_results: 'Ditemukan [COUNT] hasil untuk [SEARCH_TERM]',
            one_result: 'Ditemukan [COUNT] hasil untuk [SEARCH_TERM]',
            alt_search: 'Tidak ditemukan hasil untuk [SEARCH_TERM]. Tampilkan hasil untuk',
            search_suggestion: 'Tidak ditemukan hasil untuk [SEARCH_TERM]. Coba salah satu pencarian berikut:',
            searching: 'Mencari [SEARCH_TERM]...',
            load_more: 'Muat lebih banyak hasil',
          },
        });

        // Indonesian stemmer with nasal prefix awareness
        var noStemWords = ['menteri', 'mentari', 'mental', 'menu', 'mereka',
          'bersama', 'perlu', 'termasuk', 'setiap', 'berdasarkan'];

        // Ordered prefix rules: [pattern, replacement]
        // Longer/more-specific patterns first to avoid greedy mismatch
        var prefixRules = [
          [/^meny/, 's'],    // menyapu → sapu
          [/^mem([bp])/, '$1'], // membawa → bawa, memproses → proses
          [/^mem/, 'm'],     // memuat → muat
          [/^meng([gkh])/, '$1'], // menggali → gali
          [/^meng([aiueo])/, 'k$1'], // pengurang → kurang (k dropped by nasal)
          [/^meng/, ''],     // mengatur → atur (non-k root)
          [/^men([cdjtz])/, '$1'], // mendata → data, mencari → cari
          [/^men/, 'n'],     // menilai → nilai
          [/^me/, ''],       // melawan → lawan
          [/^peny/, 's'],    // penyebab → sebab
          [/^pem([bp])/, '$1'], // pembayar → bayar
          [/^pem/, 'm'],     // pemuat → muat
          [/^peng([gkh])/, '$1'], // pengguna → guna
          [/^peng([aiueo])/, 'k$1'], // pengurang → kurang (k dropped by nasal)
          [/^peng/, ''],     // non-k root
          [/^pen([cdjtz])/, '$1'], // pendaftar → daftar
          [/^pen/, 'n'],     // penilai → nilai
          [/^pe/, ''],       // pelaku → laku
          [/^ber/, ''],      // berlaku → laku
          [/^per/, ''],      // perkara → kara
          [/^ter/, ''],      // terbuka → buka
          [/^di/, ''],       // dibuat → buat
          [/^ke/, ''],       // ketua → tua
          [/^se/, ''],       // semua → mua
        ];

        function indonesianStem(word) {
          var s = word.toLowerCase();
          if (s.length < 4) return s;
          if (noStemWords.indexOf(s) !== -1) return s;

          // Step 1: remove suffix first (no standalone -i, causes over-stripping)
          s = s.replace(/(kan|an)$/, '');

          // Step 2: remove ONE prefix (first match wins)
          for (var i = 0; i < prefixRules.length; i++) {
            var rule = prefixRules[i];
            if (rule[0].test(s)) {
              s = s.replace(rule[0], rule[1]);
              break;
            }
          }

          return s.length > 2 ? s : word.toLowerCase();
        }

        // Watch for zero results and retry with stemmed query
        var stemNote = document.createElement('div');
        stemNote.id = 'stem-note';
        stemNote.style.cssText = 'padding:12px 16px;margin-top:8px;font-size:14px;display:none;border-radius:0;';
        stemNote.className = 'bg-amber-50 border border-amber-500 text-amber-800 dark:bg-amber-900/20 dark:border-amber-600 dark:text-amber-300';
        el.parentNode.insertBefore(stemNote, el.nextSibling);

        var lastRawQuery = '';
        var observer = new MutationObserver(function() {
          var zeroEl = el.querySelector('.pagefind-ui__message');
          var input = el.querySelector('input');
          if (!input) return;
          var currentQuery = input.value.trim();

          if (zeroEl && currentQuery && currentQuery === lastRawQuery) return;
          lastRawQuery = '';
          stemNote.style.display = 'none';

          if (!zeroEl || !currentQuery) return;
          if (zeroEl.textContent.indexOf('Tidak ditemukan') === -1) return;

          // Stem each word and retry
          var words = currentQuery.split(/\s+/);
          var stemmed = words.map(indonesianStem).filter(function(w) { return w.length > 2; });
          var stemmedQuery = stemmed.join(' ');

          if (stemmedQuery && stemmedQuery !== currentQuery.toLowerCase()) {
            lastRawQuery = currentQuery;
            stemNote.textContent = 'Menampilkan hasil untuk "' + stemmedQuery + '" (dari "' + currentQuery + '")';
            stemNote.style.display = 'block';
            input.value = stemmedQuery;
            input.dispatchEvent(new Event('input'));
          }
        });
        observer.observe(el, { childList: true, subtree: true });

        // Check for query param
        var params = new URLSearchParams(window.location.search);
        var query = params.get('q');
        if (query) {
          var input = el.querySelector('input');
          if (input) {
            input.value = query;
            input.dispatchEvent(new Event('input'));
          }
        }
      } catch (e) {
        console.error('Pagefind init failed:', e);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPagefind);
    } else {
      initPagefind();
    }
  </script>
</BaseLayout>
