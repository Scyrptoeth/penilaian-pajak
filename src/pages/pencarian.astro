---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pencarian Peraturan" description="Cari peraturan penilaian pajak dengan pencarian full-text ke dalam isi pasal dan ayat.">
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <h1 class="font-heading text-3xl font-bold tracking-tight text-navy-800 dark:text-stone-100 sm:text-4xl">
        Pencarian Peraturan
      </h1>
      <p class="mt-3 text-navy-500 dark:text-stone-400">
        Cari kata kunci, frasa, atau kalimat di dalam isi peraturan. Hasil pencarian menampilkan potongan teks yang relevan.
      </p>
    </div>

    <!-- Pagefind search widget -->
    <div class="mt-8">
      <div id="search" class="min-h-[400px]"></div>
    </div>

    <!-- Usage tips -->
    <div class="mt-12 border-2 border-navy-100 p-6 dark:border-navy-800">
      <h2 class="font-heading text-lg font-semibold text-navy-800 dark:text-stone-100">Tips Pencarian</h2>
      <ul class="mt-4 space-y-2 text-sm text-navy-600 dark:text-stone-400">
        <li class="flex items-start gap-2">
          <span class="mt-0.5 inline-block h-1.5 w-1.5 shrink-0 bg-gold-400"></span>
          <span><strong class="text-navy-800 dark:text-stone-200">Kata kunci tunggal:</strong> <code class="font-mono text-gold-600 dark:text-gold-400">penilaian</code></span>
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-0.5 inline-block h-1.5 w-1.5 shrink-0 bg-gold-400"></span>
          <span><strong class="text-navy-800 dark:text-stone-200">Multi kata kunci:</strong> <code class="font-mono text-gold-600 dark:text-gold-400">klasifikasi panas bumi</code></span>
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-0.5 inline-block h-1.5 w-1.5 shrink-0 bg-gold-400"></span>
          <span><strong class="text-navy-800 dark:text-stone-200">Frasa persis:</strong> <code class="font-mono text-gold-600 dark:text-gold-400">"nilai jual objek pajak"</code></span>
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-0.5 inline-block h-1.5 w-1.5 shrink-0 bg-gold-400"></span>
          <span><strong class="text-navy-800 dark:text-stone-200">Nomor peraturan:</strong> <code class="font-mono text-gold-600 dark:text-gold-400">PMK-79</code></span>
        </li>
      </ul>
    </div>
  </section>

  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      if (typeof PagefindUI !== 'undefined') {
        new PagefindUI({
          element: '#search',
          showSubResults: true,
          showImages: false,
          translations: {
            placeholder: 'Cari di dalam isi peraturan...',
            zero_results: 'Tidak ditemukan hasil untuk "[SEARCH_TERM]"',
            many_results: '{count} hasil ditemukan',
            one_result: '1 hasil ditemukan',
            searching: 'Mencari...',
          },
        });
      }

      // Check for query param
      const params = new URLSearchParams(window.location.search);
      const query = params.get('q');
      if (query) {
        const input = document.querySelector('#search input');
        if (input) {
          input.value = query;
          input.dispatchEvent(new Event('input'));
        }
      }
    });
  </script>
</BaseLayout>
