---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pencarian Peraturan" description="Cari peraturan penilaian pajak dengan pencarian full-text ke dalam isi pasal dan ayat.">
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <h1 class="font-heading text-3xl font-bold tracking-tight text-navy-800 dark:text-stone-100 sm:text-4xl">
        Pencarian Peraturan
      </h1>
      <p class="mt-3 text-navy-500 dark:text-stone-400">
        Cari kata kunci, frasa, atau kalimat di dalam isi peraturan. Hasil pencarian menampilkan potongan teks yang relevan.
      </p>
    </div>

    <!-- Pagefind search widget -->
    <div class="mt-8">
      <div id="search" class="min-h-[400px]"></div>
    </div>

    <!-- Usage tips -->
    <div class="mt-12 border-2 border-navy-100 p-6 dark:border-navy-800">
      <h2 class="font-heading text-lg font-semibold text-navy-800 dark:text-stone-100">Tips Pencarian</h2>
      <ul class="mt-4 space-y-2 text-sm text-navy-600 dark:text-stone-400">
        <li class="flex items-start gap-2">
          <span class="mt-0.5 inline-block h-1.5 w-1.5 shrink-0 bg-gold-400"></span>
          <span><strong class="text-navy-800 dark:text-stone-200">Kata kunci tunggal:</strong> <code class="font-mono text-gold-600 dark:text-gold-400">penilaian</code></span>
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-0.5 inline-block h-1.5 w-1.5 shrink-0 bg-gold-400"></span>
          <span><strong class="text-navy-800 dark:text-stone-200">Multi kata kunci:</strong> <code class="font-mono text-gold-600 dark:text-gold-400">klasifikasi panas bumi</code></span>
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-0.5 inline-block h-1.5 w-1.5 shrink-0 bg-gold-400"></span>
          <span><strong class="text-navy-800 dark:text-stone-200">Frasa persis:</strong> <code class="font-mono text-gold-600 dark:text-gold-400">"nilai jual objek pajak"</code></span>
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-0.5 inline-block h-1.5 w-1.5 shrink-0 bg-gold-400"></span>
          <span><strong class="text-navy-800 dark:text-stone-200">Nomor peraturan:</strong> <code class="font-mono text-gold-600 dark:text-gold-400">PMK-79</code></span>
        </li>
      </ul>
    </div>
  </section>

  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script is:inline>
    async function initPagefind() {
      try {
        const el = document.getElementById('search');
        if (!el) return;

        // Dynamic import is more reliable than external script tag
        await import('/pagefind/pagefind-ui.js');

        if (typeof PagefindUI === 'undefined') return;

        new PagefindUI({
          element: '#search',
          showSubResults: true,
          showImages: false,
          translations: {
            placeholder: 'Cari di dalam isi peraturan...',
            zero_results: 'Tidak ditemukan hasil untuk "[SEARCH_TERM]"',
            many_results: 'Ditemukan [COUNT] hasil untuk [SEARCH_TERM]',
            one_result: 'Ditemukan [COUNT] hasil untuk [SEARCH_TERM]',
            alt_search: 'Tidak ditemukan hasil untuk [SEARCH_TERM]. Tampilkan hasil untuk',
            search_suggestion: 'Tidak ditemukan hasil untuk [SEARCH_TERM]. Coba salah satu pencarian berikut:',
            searching: 'Mencari [SEARCH_TERM]...',
            load_more: 'Muat lebih banyak hasil',
          },
        });

        // === GOOGLE-LIKE SEARCH BEHAVIOR ===
        // 1. "exact phrase" in quotes → never stem
        // 2. plain words → stem only on zero results, show as suggestion (not replace)
        // 3. Strip punctuation before stemming
        // 4. Expanded noStemWords for common Indonesian tax/legal terms

        // --- No-stem word list ---
        // Words that should NEVER be stemmed because stemming changes their meaning
        var noStemWords = [
          // Common Indonesian words that break when stemmed
          'menteri', 'mentari', 'mental', 'menu', 'mereka',
          'bersama', 'perlu', 'termasuk', 'setiap', 'berdasarkan',
          // Tax/legal terms - stemming changes meaning significantly
          'pendekatan',   // approach ≠ dekat (near)
          'penilaian',    // assessment ≠ nilai (value)
          'peraturan',    // regulation ≠ atur (arrange)
          'pemerintah',   // government ≠ perintah (command)
          'pembangunan',  // development ≠ bangun (build)
          'pendapatan',   // income ≠ dapat (get)
          'pengelolaan',  // management ≠ kelola (manage) — actually similar but keep for precision
          'penghasilan',  // income ≠ hasil (result)
          'keputusan',    // decision ≠ putus (break)
          'penetapan',    // determination ≠ tetap (fixed)
          'perhitungan',  // calculation ≠ hitung (count)
          'persyaratan',  // requirement ≠ syarat (condition) — similar but keep
          'pelaksanaan',  // implementation ≠ laksana (manner)
          'pengurangan',  // reduction/deduction ≠ kurang (less)
          'perpajakan',   // taxation ≠ pajak (tax) — similar but keep for precision
          'pembayaran',   // payment ≠ bayar (pay) — similar but keep
          'pengembalian',  // return/refund ≠ kembali (return verb)
          'pemeriksaan',  // examination ≠ periksa (check)
          'pemanfaatan',  // utilization
          'pengenaan',    // imposition
          'penentuan',    // determination
          'ketentuan',    // provision
          'kewajiban',    // obligation
          'wewenang',     // authority
          'kewenangan',   // authority (noun)
        ];

        // --- Prefix rules (unchanged logic) ---
        var prefixRules = [
          [/^meny/, 's'],
          [/^mem([bp])/, '$1'],
          [/^mem/, 'm'],
          [/^meng([gkh])/, '$1'],
          [/^meng([aiueo])/, 'k$1'],
          [/^meng/, ''],
          [/^men([cdjtz])/, '$1'],
          [/^men/, 'n'],
          [/^me/, ''],
          [/^peny/, 's'],
          [/^pem([bp])/, '$1'],
          [/^pem/, 'm'],
          [/^peng([gkh])/, '$1'],
          [/^peng([aiueo])/, 'k$1'],
          [/^peng/, ''],
          [/^pen([cdjtz])/, '$1'],
          [/^pen/, 'n'],
          [/^pe/, ''],
          [/^ber/, ''],
          [/^per/, ''],
          [/^ter/, ''],
          [/^di/, ''],
          [/^ke/, ''],
          [/^se/, ''],
        ];

        // --- Stem function (with punctuation stripping) ---
        function indonesianStem(word) {
          // Strip all non-letter characters (quotes, commas, etc.)
          var cleaned = word.toLowerCase().replace(/[^a-z]/g, '');
          if (cleaned.length < 4) return cleaned;
          if (noStemWords.indexOf(cleaned) !== -1) return cleaned;

          var s = cleaned;

          // Step 1: remove suffix (no standalone -i, causes over-stripping)
          s = s.replace(/(kan|an)$/, '');

          // Step 2: remove ONE prefix (first match wins)
          for (var i = 0; i < prefixRules.length; i++) {
            var rule = prefixRules[i];
            if (rule[0].test(s)) {
              s = s.replace(rule[0], rule[1]);
              break;
            }
          }

          return s.length > 2 ? s : cleaned;
        }

        // --- Query parser: separate quoted phrases from plain words ---
        function parseQuery(query) {
          var quoted = [];
          var plain = [];
          // Extract "exact phrases" first
          var withoutQuoted = query.replace(/"([^"]+)"/g, function(match, phrase) {
            quoted.push(phrase);
            return '';
          });
          // Remaining words are plain (unquoted)
          var remaining = withoutQuoted.trim().split(/\s+/).filter(function(w) {
            return w.length > 0;
          });
          // Clean any stray quotes from remaining words
          plain = remaining.map(function(w) {
            return w.replace(/"/g, '');
          }).filter(function(w) {
            return w.length > 0;
          });
          return { quoted: quoted, plain: plain };
        }

        // --- Suggestion UI (Google-like "Showing results for X. Search instead for Y") ---
        var stemContainer = document.createElement('div');
        stemContainer.id = 'stem-container';
        stemContainer.style.cssText = 'margin-top:8px;display:none;';
        el.parentNode.insertBefore(stemContainer, el.nextSibling);

        var isStemmedSearch = false;
        var originalQuery = '';
        var lastProcessedQuery = '';

        var observer = new MutationObserver(function() {
          var zeroEl = el.querySelector('.pagefind-ui__message');
          var input = el.querySelector('input');
          if (!input) return;
          var currentQuery = input.value.trim();

          // Skip if we already processed this exact query
          if (currentQuery === lastProcessedQuery) return;

          // If user is viewing stemmed results and types new query, reset
          if (isStemmedSearch && currentQuery !== lastProcessedQuery) {
            isStemmedSearch = false;
            originalQuery = '';
            stemContainer.style.display = 'none';
            stemContainer.innerHTML = '';
          }

          // Only act on zero results
          if (!zeroEl || !currentQuery) {
            stemContainer.style.display = 'none';
            stemContainer.innerHTML = '';
            lastProcessedQuery = '';
            return;
          }
          if (zeroEl.textContent.indexOf('Tidak ditemukan') === -1) {
            stemContainer.style.display = 'none';
            stemContainer.innerHTML = '';
            lastProcessedQuery = '';
            return;
          }

          // Don't stem if this is already a stemmed retry
          if (isStemmedSearch) return;

          // Parse query for quoted phrases vs plain words
          var parsed = parseQuery(currentQuery);

          // If entire query is a quoted phrase → DON'T stem at all
          // (User explicitly wants exact match)
          if (parsed.quoted.length > 0 && parsed.plain.length === 0) {
            // Show helpful tip instead
            stemContainer.innerHTML = '<div class="bg-blue-50 border border-blue-300 text-blue-800 dark:bg-blue-900/20 dark:border-blue-700 dark:text-blue-300" style="padding:12px 16px;font-size:14px;">'
              + '<strong>Tip:</strong> Pencarian dengan tanda kutip mencari frasa persis. '
              + 'Coba tanpa tanda kutip untuk hasil lebih luas: '
              + '<a href="#" id="stem-remove-quotes" style="text-decoration:underline;font-weight:600;">'
              + parsed.quoted.join(' ')
              + '</a>'
              + '</div>';
            stemContainer.style.display = 'block';
            lastProcessedQuery = currentQuery;

            // Handle click: search without quotes
            var removeQuotesLink = document.getElementById('stem-remove-quotes');
            if (removeQuotesLink) {
              removeQuotesLink.addEventListener('click', function(e) {
                e.preventDefault();
                var unquoted = parsed.quoted.join(' ');
                input.value = unquoted;
                input.dispatchEvent(new Event('input'));
                stemContainer.style.display = 'none';
                stemContainer.innerHTML = '';
                lastProcessedQuery = '';
              });
            }
            return;
          }

          // For unquoted queries: try stemmed version
          // Only stem the plain (unquoted) words
          var wordsToStem = parsed.plain;
          var stemmedWords = wordsToStem.map(indonesianStem).filter(function(w) {
            return w.length > 2;
          });

          // Reconstruct: quoted phrases stay as-is + stemmed plain words
          var stemmedParts = [];
          parsed.quoted.forEach(function(q) {
            stemmedParts.push('"' + q + '"');
          });
          stemmedWords.forEach(function(w) {
            stemmedParts.push(w);
          });
          var stemmedQuery = stemmedParts.join(' ');

          // Only suggest if stemmed version is actually different
          if (!stemmedQuery || stemmedQuery.toLowerCase() === currentQuery.toLowerCase()) {
            lastProcessedQuery = currentQuery;
            return;
          }

          // Show Google-like suggestion WITHOUT overwriting input
          originalQuery = currentQuery;
          lastProcessedQuery = currentQuery;

          stemContainer.innerHTML = '<div class="bg-amber-50 border border-amber-500 text-amber-800 dark:bg-amber-900/20 dark:border-amber-600 dark:text-amber-300" style="padding:12px 16px;font-size:14px;">'
            + 'Tidak ditemukan hasil. Menampilkan hasil untuk '
            + '<a href="#" id="stem-try-link" style="font-weight:700;text-decoration:underline;">' + stemmedQuery + '</a>'
            + '<br><span style="font-size:13px;opacity:0.8;">Cari persis: '
            + '<a href="#" id="stem-revert-link" style="font-weight:600;text-decoration:underline;">' + currentQuery + '</a>'
            + '</span>'
            + '</div>';
          stemContainer.style.display = 'block';

          // Handle click: try stemmed query
          var tryLink = document.getElementById('stem-try-link');
          if (tryLink) {
            tryLink.addEventListener('click', function(e) {
              e.preventDefault();
              isStemmedSearch = true;
              originalQuery = currentQuery;
              input.value = stemmedQuery;
              lastProcessedQuery = stemmedQuery;
              input.dispatchEvent(new Event('input'));

              // Update suggestion to show revert option
              stemContainer.innerHTML = '<div class="bg-amber-50 border border-amber-500 text-amber-800 dark:bg-amber-900/20 dark:border-amber-600 dark:text-amber-300" style="padding:12px 16px;font-size:14px;">'
                + 'Menampilkan hasil untuk <strong>' + stemmedQuery + '</strong>'
                + '<br><span style="font-size:13px;opacity:0.8;">Cari persis: '
                + '<a href="#" id="stem-revert-link-2" style="font-weight:600;text-decoration:underline;">' + originalQuery + '</a>'
                + '</span>'
                + '</div>';

              var revertLink2 = document.getElementById('stem-revert-link-2');
              if (revertLink2) {
                revertLink2.addEventListener('click', function(e2) {
                  e2.preventDefault();
                  isStemmedSearch = false;
                  input.value = originalQuery;
                  lastProcessedQuery = '';
                  input.dispatchEvent(new Event('input'));
                  stemContainer.style.display = 'none';
                  stemContainer.innerHTML = '';
                });
              }
            });
          }

          // Handle click: revert to original
          var revertLink = document.getElementById('stem-revert-link');
          if (revertLink) {
            revertLink.addEventListener('click', function(e) {
              e.preventDefault();
              stemContainer.style.display = 'none';
              stemContainer.innerHTML = '';
              lastProcessedQuery = '';
            });
          }
        });
        observer.observe(el, { childList: true, subtree: true });

        // Check for query param
        var params = new URLSearchParams(window.location.search);
        var query = params.get('q');
        if (query) {
          var input = el.querySelector('input');
          if (input) {
            input.value = query;
            input.dispatchEvent(new Event('input'));
          }
        }
      } catch (e) {
        console.error('Pagefind init failed:', e);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPagefind);
    } else {
      initPagefind();
    }
  </script>
</BaseLayout>
