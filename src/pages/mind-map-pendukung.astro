---
import BaseLayout from '../layouts/BaseLayout.astro';
import MindMapPendukung from '../components/MindMapPendukung';
import { getCollection } from 'astro:content';

const regulations = await getCollection('regulations-pendukung');

// --- Theme categories (approved in Fase 1) ---

interface Category {
  id: string;
  label: string;
  match: (topik: string[]) => boolean;
}

const categories: Category[] = [
  { id: 'penerimaan_alokasi', label: 'Penerimaan & Alokasi Dana', match: (topik) => topik.includes('penerimaan_alokasi') },
  { id: 'pendataan_pendaftaran', label: 'Pendataan & Pendaftaran', match: (topik) => topik.includes('pendataan_pendaftaran') },
  { id: 'pengurangan_keberatan', label: 'Keberatan & Pengurangan', match: (topik) => topik.includes('pengurangan_keberatan') },
  { id: 'pengenaan_sektoral', label: 'Pengenaan PBB Sektoral', match: (topik) => topik.includes('pengenaan_sektoral') },
  { id: 'klasifikasi_njop', label: 'Klasifikasi & Penetapan NJOP', match: (topik) => topik.includes('klasifikasi_njop') },
  { id: 'pembayaran_penagihan', label: 'Pembayaran & Penagihan', match: (topik) => topik.includes('pembayaran_penagihan') },
  { id: 'pengenaan_objek_khusus', label: 'Pengenaan Objek Khusus', match: (topik) => topik.includes('pengenaan_objek_khusus') },
  { id: 'penerbitan_dokumen', label: 'Penerbitan Dokumen & Formulir', match: (topik) => topik.includes('penerbitan_dokumen') },
  { id: 'dasar_hukum_kebijakan', label: 'Dasar Hukum & Kebijakan', match: (topik) => topik.includes('dasar_hukum_kebijakan') },
  { id: 'penilaian_teknis', label: 'Penilaian & Parameter Teknis', match: (topik) => topik.includes('penilaian_teknis') },
  { id: 'petunjuk_sektoral', label: 'Petunjuk Teknis Sektoral', match: (topik) => topik.includes('petunjuk_sektoral') },
  { id: 'organisasi_pelayanan', label: 'Organisasi & Pelayanan', match: (topik) => topik.includes('organisasi_pelayanan') },
  { id: 'p2_perkotaan', label: 'PBB P2 (Perdesaan & Perkotaan)', match: (topik) => topik.includes('p2_perkotaan') },
];

// --- Assign regulations to categories ---

const categoryRegMap = new Map<string, typeof regulations>();
for (const cat of categories) {
  categoryRegMap.set(cat.id, []);
}
categoryRegMap.set('lainnya', []);

for (const reg of regulations) {
  const topik = reg.data.topik || [];
  let assigned = false;
  for (const cat of categories) {
    if (cat.match(topik)) {
      categoryRegMap.get(cat.id)!.push(reg);
      assigned = true;
      break;
    }
  }
  if (!assigned) {
    categoryRegMap.get('lainnya')!.push(reg);
  }
}

// Build categorized data (filter empty)
const categorizedData = [
  ...categories.map((cat) => ({
    id: cat.id,
    label: cat.label,
    regulations: categoryRegMap.get(cat.id) || [],
  })),
  {
    id: 'lainnya',
    label: 'Lainnya',
    regulations: categoryRegMap.get('lainnya') || [],
  },
].filter((cat) => cat.regulations.length > 0);

// --- Sub-group large categories by era ---

const SUB_GROUP_THRESHOLD = 30;

interface EraGroup {
  id: string;
  label: string;
  regulations: typeof regulations;
}

function getEraGroups(catId: string, regs: typeof regulations): EraGroup[] {
  if (regs.length <= SUB_GROUP_THRESHOLD) return [];
  const byEra = new Map<string, typeof regulations>();
  for (const reg of regs) {
    const year = reg.data.tahun;
    const era = year < 2000 ? '1985-1999' : year < 2010 ? '2000-2009' : year < 2020 ? '2010-2019' : '2020-2025';
    if (!byEra.has(era)) byEra.set(era, []);
    byEra.get(era)!.push(reg);
  }
  return [...byEra.entries()]
    .sort((a, b) => a[0].localeCompare(b[0]))
    .filter(([, regs]) => regs.length > 0)
    .map(([era, eraRegs]) => ({ id: `${catId}-${era}`, label: `${era}`, regulations: eraRegs }));
}

// --- Build React Flow nodes and edges ---

const ROOT_ID = 'root';

const nodes: Array<{
  id: string;
  type: string;
  position: { x: number; y: number };
  data: Record<string, unknown>;
}> = [
  {
    id: ROOT_ID,
    type: 'root',
    position: { x: 0, y: 0 },
    data: { label: `Peraturan Pendukung PBB (${regulations.length})`, nodeType: 'root' },
  },
];

const edges: Array<{
  id: string;
  source: string;
  target: string;
  type?: string;
  style?: Record<string, unknown>;
}> = [];

for (const cat of categorizedData) {
  const catNodeId = `cat-${cat.id}`;
  const subGroups = getEraGroups(cat.id, cat.regulations);

  nodes.push({
    id: catNodeId,
    type: 'category',
    position: { x: 0, y: 0 },
    data: { label: cat.label, count: cat.regulations.length, categoryId: cat.id, nodeType: 'category' },
  });
  edges.push({
    id: `${ROOT_ID}-${catNodeId}`,
    source: ROOT_ID,
    target: catNodeId,
    type: 'smoothstep',
    style: { stroke: '#1a5090', strokeWidth: 2 },
  });

  if (subGroups.length > 0) {
    for (const sub of subGroups) {
      const subCatId = `cat-${sub.id}`;
      nodes.push({
        id: subCatId,
        type: 'category',
        position: { x: 0, y: 0 },
        data: { label: sub.label, count: sub.regulations.length, categoryId: sub.id, nodeType: 'category' },
      });
      edges.push({ id: `${catNodeId}-${subCatId}`, source: catNodeId, target: subCatId, style: { stroke: '#334155', strokeWidth: 1.5 } });

      for (const reg of sub.regulations) {
        const slug = reg.id.split('/').pop() || reg.id;
        const regNodeId = `reg-${slug}`;
        nodes.push({
          id: regNodeId,
          type: 'regulation',
          position: { x: 0, y: 0 },
          data: { label: reg.data.nomor, title: reg.data.deskripsi || reg.data.title, jenis: reg.data.jenis, status: reg.data.status, slug, nodeType: 'regulation' },
        });
        edges.push({ id: `${subCatId}-${regNodeId}`, source: subCatId, target: regNodeId, style: { stroke: '#94a3b8' } });
      }
    }
  } else {
    for (const reg of cat.regulations) {
      const slug = reg.id.split('/').pop() || reg.id;
      const regNodeId = `reg-${slug}`;
      nodes.push({
        id: regNodeId,
        type: 'regulation',
        position: { x: 0, y: 0 },
        data: { label: reg.data.nomor, title: reg.data.deskripsi || reg.data.title, jenis: reg.data.jenis, status: reg.data.status, slug, nodeType: 'regulation' },
      });
      edges.push({ id: `${catNodeId}-${regNodeId}`, source: catNodeId, target: regNodeId, style: { stroke: '#94a3b8' } });
    }
  }
}

const statusColors: Record<string, string> = {
  berlaku: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400',
  dicabut: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400',
  diubah: 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400',
};
---

<BaseLayout title="Mind Map Peraturan Pendukung" description="Visualisasi hubungan antar 337 peraturan pendukung PBB dalam bentuk mind map interaktif berbasis tema.">
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="font-heading text-3xl font-bold tracking-tight text-navy-800 dark:text-stone-100">
      Peta Peraturan Pendukung
    </h1>
    <p class="mt-2 text-navy-500 dark:text-stone-400">
      {regulations.length} peraturan pendukung PBB dikelompokkan berdasarkan tema. Klik kategori untuk expand, klik peraturan untuk detail.
    </p>

    <!-- Legend -->
    <div class="mt-6 flex flex-wrap gap-3 text-xs sm:gap-4 sm:text-sm">
      <div class="flex items-center gap-1.5">
        <span class="h-3 w-3 bg-green-500"></span>
        <span class="text-navy-600 dark:text-stone-400">Berlaku</span>
      </div>
      <div class="flex items-center gap-1.5">
        <span class="h-3 w-3 bg-red-500"></span>
        <span class="text-navy-600 dark:text-stone-400">Dicabut</span>
      </div>
      <div class="flex items-center gap-1.5">
        <span class="h-3 w-3 bg-blue-500"></span>
        <span class="text-navy-600 dark:text-stone-400">Diubah</span>
      </div>
      <div class="flex items-center gap-1.5">
        <span class="h-3 w-3 bg-navy-700 dark:bg-navy-400"></span>
        <span class="text-navy-600 dark:text-stone-400">Kategori</span>
      </div>
    </div>
  </section>

  <!-- Data for React Flow (embedded as JSON script tags) -->
  <script id="mindmap-nodes" type="application/json" set:html={JSON.stringify(nodes)} />
  <script id="mindmap-edges" type="application/json" set:html={JSON.stringify(edges)} />

  <!-- Desktop: React Flow mind map -->
  <div class="hidden border-t-2 border-navy-100 bg-white dark:border-navy-800 dark:bg-navy-900 md:block" style="height: calc(100vh - 200px); min-height: 500px;">
    <MindMapPendukung client:only="react" />
  </div>

  <!-- Mobile: Accordion fallback -->
  <div class="border-t-2 border-navy-100 dark:border-navy-800 md:hidden">
    <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6">
      <p class="mb-4 text-sm text-navy-500 dark:text-stone-400">
        Gunakan perangkat desktop untuk melihat mind map interaktif. Di bawah ini daftar peraturan per tema.
      </p>
      {categorizedData.map((cat) => {
        const subGroups = getEraGroups(cat.id, cat.regulations);
        return (
          <details class="group border-b border-navy-100 dark:border-navy-800">
            <summary class="flex cursor-pointer items-center justify-between py-4 font-heading font-semibold text-navy-800 dark:text-stone-100">
              <span>{cat.label} <span class="ml-2 text-sm font-normal text-navy-400 dark:text-stone-500">({cat.regulations.length})</span></span>
              <svg class="h-5 w-5 shrink-0 text-navy-400 transition-transform group-open:rotate-180 dark:text-stone-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 011.06 0L10 11.94l3.72-3.72a.75.75 0 111.06 1.06l-4.25 4.25a.75.75 0 01-1.06 0L5.22 9.28a.75.75 0 010-1.06z" clip-rule="evenodd" />
              </svg>
            </summary>
            {subGroups.length > 0 ? (
              <div class="pb-4 pl-2">
                {subGroups.map((sub) => (
                  <details class="group/sub border-l-2 border-navy-200 pl-4 dark:border-navy-700">
                    <summary class="flex cursor-pointer items-center justify-between py-2 text-sm font-medium text-navy-700 dark:text-stone-200">
                      <span>{sub.label} <span class="text-navy-400 dark:text-stone-500">({sub.regulations.length})</span></span>
                      <svg class="h-4 w-4 shrink-0 text-navy-400 transition-transform group-open/sub:rotate-180 dark:text-stone-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 011.06 0L10 11.94l3.72-3.72a.75.75 0 111.06 1.06l-4.25 4.25a.75.75 0 01-1.06 0L5.22 9.28a.75.75 0 010-1.06z" clip-rule="evenodd" />
                      </svg>
                    </summary>
                    <ul class="space-y-2 py-2 pl-2">
                      {sub.regulations.map((reg) => (
                        <li>
                          <a href={`/peraturan-pendukung/${reg.id}`} class="flex items-center gap-2 py-1 text-sm">
                            <span class={`shrink-0 px-1.5 py-0.5 text-xs font-medium capitalize ${statusColors[reg.data.status]}`}>{reg.data.status}</span>
                            <span class="font-mono text-xs font-medium text-navy-700 dark:text-stone-300">{reg.data.nomor}</span>
                            <span class="truncate text-navy-500 dark:text-stone-400">{reg.data.deskripsi || reg.data.title}</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </details>
                ))}
              </div>
            ) : (
              <ul class="space-y-2 pb-4 pl-2">
                {cat.regulations.map((reg) => (
                  <li>
                    <a href={`/peraturan-pendukung/${reg.id}`} class="flex items-center gap-2 py-1 text-sm">
                      <span class={`shrink-0 px-1.5 py-0.5 text-xs font-medium capitalize ${statusColors[reg.data.status]}`}>{reg.data.status}</span>
                      <span class="font-mono text-xs font-medium text-navy-700 dark:text-stone-300">{reg.data.nomor}</span>
                      <span class="truncate text-navy-500 dark:text-stone-400">{reg.data.deskripsi || reg.data.title}</span>
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </details>
        );
      })}
    </div>
  </div>
</BaseLayout>
