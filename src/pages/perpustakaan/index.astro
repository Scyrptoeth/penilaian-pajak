---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const regulations = await getCollection('regulations');

// Sort by year (newest first), then by jenis
const sorted = regulations.sort((a, b) => {
  if (b.data.tahun !== a.data.tahun) return b.data.tahun - a.data.tahun;
  return a.data.nomor.localeCompare(b.data.nomor);
});

// Extract unique filter values
const jenisOptions = [...new Set(regulations.map((r) => r.data.jenis))].sort();
const tahunOptions = [...new Set(regulations.map((r) => r.data.tahun))].sort((a, b) => b - a);
const statusOptions = ['berlaku', 'dicabut', 'diubah'];

const statusColors: Record<string, string> = {
  berlaku: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400',
  dicabut: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400',
  diubah: 'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400',
};

const jenisColors: Record<string, string> = {
  UU: 'bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-400',
  PP: 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400',
  PMK: 'bg-navy-100 text-navy-800 dark:bg-navy-800 dark:text-navy-200',
  PER: 'bg-teal-100 text-teal-800 dark:bg-teal-900/30 dark:text-teal-400',
  SE: 'bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-400',
  KEP: 'bg-pink-100 text-pink-800 dark:bg-pink-900/30 dark:text-pink-400',
  KMK: 'bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-400',
  KEPPRES: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400',
};
---

<BaseLayout title="Peraturan Inti" description="Daftar lengkap peraturan inti penilaian pajak Indonesia — filter berdasarkan jenis, tahun, dan status.">
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-start">
      <!-- Sidebar filters -->
      <aside class="w-full shrink-0 border-2 border-navy-100 dark:border-navy-800 lg:w-64">
        <details class="group lg:open" open>
          <summary class="flex cursor-pointer items-center justify-between p-5 font-heading text-sm font-semibold tracking-widest text-navy-800 uppercase dark:text-stone-100 lg:pointer-events-none lg:cursor-default">
            Filter
            <svg class="h-5 w-5 shrink-0 text-navy-400 transition-transform group-open:rotate-180 dark:text-stone-500 lg:hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 011.06 0L10 11.94l3.72-3.72a.75.75 0 111.06 1.06l-4.25 4.25a.75.75 0 01-1.06 0L5.22 9.28a.75.75 0 010-1.06z" clip-rule="evenodd" />
            </svg>
          </summary>
          <div class="space-y-5 px-5 pb-5" id="filters">
            <!-- Jenis -->
            <fieldset>
              <legend class="text-xs font-medium tracking-wide text-navy-500 uppercase dark:text-stone-400">Jenis Peraturan</legend>
              <div class="mt-2 space-y-1.5">
                {jenisOptions.map((jenis) => (
                  <label class="flex cursor-pointer items-center gap-2 text-sm text-navy-700 dark:text-stone-300">
                    <input type="checkbox" value={jenis} data-filter="jenis" class="accent-gold-400" />
                    {jenis}
                  </label>
                ))}
              </div>
            </fieldset>

            <!-- Status -->
            <fieldset>
              <legend class="text-xs font-medium tracking-wide text-navy-500 uppercase dark:text-stone-400">Status</legend>
              <div class="mt-2 space-y-1.5">
                {statusOptions.map((status) => (
                  <label class="flex cursor-pointer items-center gap-2 text-sm capitalize text-navy-700 dark:text-stone-300">
                    <input type="checkbox" value={status} data-filter="status" class="accent-gold-400" />
                    {status}
                  </label>
                ))}
              </div>
            </fieldset>

            <!-- Tahun -->
            <fieldset>
              <legend class="text-xs font-medium tracking-wide text-navy-500 uppercase dark:text-stone-400">Tahun</legend>
              <div class="mt-2 space-y-1.5 max-h-40 overflow-y-auto">
                {tahunOptions.map((tahun) => (
                  <label class="flex cursor-pointer items-center gap-2 text-sm text-navy-700 dark:text-stone-300">
                    <input type="checkbox" value={tahun.toString()} data-filter="tahun" class="accent-gold-400" />
                    {tahun}
                  </label>
                ))}
              </div>
            </fieldset>

            <button id="reset-filters" class="w-full border border-navy-200 py-2 text-xs font-medium text-navy-600 transition-colors hover:bg-navy-50 dark:border-navy-700 dark:text-stone-400 dark:hover:bg-navy-800">
              Reset Filter
            </button>
          </div>
        </details>
      </aside>

      <!-- Regulation list -->
      <div class="flex-1">
        <div class="flex items-center justify-between">
          <h1 class="font-heading text-3xl font-bold tracking-tight text-navy-800 dark:text-stone-100">
            Peraturan Inti
          </h1>
          <p class="text-sm text-navy-500 dark:text-stone-400">
            <span id="visible-count">{sorted.length}</span> peraturan
          </p>
        </div>

        <div class="mt-6 space-y-3" id="regulation-list">
          {sorted.map((reg) => (
            <a
              href={`/perpustakaan/${reg.id}`}
              class="regulation-item block border-2 border-navy-100 p-5 transition-all hover:border-gold-400 dark:border-navy-800 dark:hover:border-gold-400"
              data-jenis={reg.data.jenis}
              data-status={reg.data.status}
              data-tahun={reg.data.tahun}
            >
              <div class="flex flex-wrap items-start gap-2">
                <span class={`inline-block px-2 py-0.5 font-mono text-xs font-medium ${jenisColors[reg.data.jenis] || ''}`}>
                  {reg.data.jenis}
                </span>
                <span class={`inline-block px-2 py-0.5 text-xs font-medium capitalize ${statusColors[reg.data.status] || ''}`}>
                  {reg.data.status}
                </span>
                <span class="ml-auto font-mono text-xs text-navy-400 dark:text-stone-500">{reg.data.tahun}</span>
              </div>
              <h3 class="mt-2 font-heading text-base font-semibold text-navy-800 dark:text-stone-100">
                {reg.data.nomor}
              </h3>
              <p class="mt-1 text-sm font-medium text-navy-700 dark:text-stone-200">
                {reg.data.title}
              </p>
              <p class="mt-2 line-clamp-2 text-sm text-navy-500 dark:text-stone-400">
                {reg.data.ringkasan}
              </p>
            </a>
          ))}
        </div>

        {sorted.length === 0 && (
          <div class="mt-12 text-center">
            <p class="text-navy-500 dark:text-stone-400">Belum ada peraturan yang ditambahkan.</p>
          </div>
        )}
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const checkboxes = document.querySelectorAll('[data-filter]');
      const items = document.querySelectorAll('.regulation-item');
      const countEl = document.getElementById('visible-count');
      const resetBtn = document.getElementById('reset-filters');

      function applyFilters() {
        const filters = {};
        checkboxes.forEach((cb) => {
          const key = cb.dataset.filter;
          if (cb.checked) {
            if (!filters[key]) filters[key] = [];
            filters[key].push(cb.value);
          }
        });

        let visible = 0;
        items.forEach((item) => {
          let show = true;
          for (const [key, values] of Object.entries(filters)) {
            if (!values.includes(item.dataset[key]?.toString())) {
              show = false;
              break;
            }
          }
          item.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        if (countEl) countEl.textContent = visible.toString();
      }

      checkboxes.forEach((cb) => cb.addEventListener('change', applyFilters));
      resetBtn?.addEventListener('click', () => {
        checkboxes.forEach((cb) => (cb.checked = false));
        applyFilters();
      });
    });
  </script>

  <style>
    /* On desktop, always show filter content (override closed state) */
    @media (min-width: 1024px) {
      aside details {
        pointer-events: auto;
      }
      aside details > summary {
        list-style: none;
      }
      aside details > summary::-webkit-details-marker {
        display: none;
      }
    }
  </style>
</BaseLayout>
