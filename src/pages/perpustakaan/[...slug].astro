---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const regulations = await getCollection('regulations');
  return regulations.map((reg) => ({
    params: { slug: reg.id },
    props: { regulation: reg },
  }));
}

const { regulation } = Astro.props;
const { Content } = await render(regulation);
const { data } = regulation;

// Find related regulations
const allRegulations = await getCollection('regulations');
const relatedMap = new Map(allRegulations.map((r) => [r.data.nomor, r]));

// Build cross-reference map: nomor → slug URL
const crossRefMap: Record<string, string> = {};
allRegulations.forEach((r) => {
  const nomor = r.data.nomor;
  const url = `/perpustakaan/${r.id}`;
  crossRefMap[nomor] = url;
  // Also add simplified patterns for matching
  // "PMK-79/PMK.03/2023" → extract "79/PMK.03/2023"
  const parts = nomor.match(/(\d+)\/([^/]+)\/(\d{4})/);
  if (parts) {
    crossRefMap[`${parts[1]}/${parts[2]}/${parts[3]}`] = url;
  }
});

const statusColors: Record<string, string> = {
  berlaku: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400',
  dicabut: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400',
  diubah: 'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400',
};

interface RelatedItem {
  label: string;
  items: string[];
}

const relations: RelatedItem[] = [
  { label: 'Mencabut', items: data.mencabut || [] },
  { label: 'Dicabut oleh', items: data.dicabut_oleh ? [data.dicabut_oleh] : [] },
  { label: 'Mengubah', items: data.mengubah ? [data.mengubah] : [] },
  { label: 'Diubah oleh', items: data.diubah_oleh || [] },
  { label: 'Dasar hukum', items: data.dasar_hukum ? [data.dasar_hukum] : [] },
].filter((r) => r.items.length > 0);

// Generate search keywords from topics + common tax terms
const searchKeywords = [
  ...data.topik,
  data.nomor,
  data.jenis,
  data.title,
  'pajak', 'penilaian', 'penilai', 'nilai', 'menilai',
  'peraturan', 'menteri', 'keuangan',
].join(', ');
---

<BaseLayout title={`${data.nomor} — ${data.title}`} description={data.ringkasan}>
  <article class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="py-2">
      <ol class="flex flex-wrap items-center gap-1.5 text-sm">
        <li>
          <a href="/" class="text-navy-400 transition-colors hover:text-navy-700 dark:text-stone-500 dark:hover:text-stone-200">Beranda</a>
        </li>
        <li class="text-navy-300 dark:text-stone-600" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="h-3.5 w-3.5">
            <path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 011.06 0l3.25 3.25a.75.75 0 010 1.06l-3.25 3.25a.75.75 0 01-1.06-1.06L8.94 8 6.22 5.28a.75.75 0 010-1.06z" clip-rule="evenodd" />
          </svg>
        </li>
        <li>
          <a href="/perpustakaan" class="text-navy-400 transition-colors hover:text-navy-700 dark:text-stone-500 dark:hover:text-stone-200">Perpustakaan</a>
        </li>
        <li class="text-navy-300 dark:text-stone-600" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="h-3.5 w-3.5">
            <path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 011.06 0l3.25 3.25a.75.75 0 010 1.06l-3.25 3.25a.75.75 0 01-1.06-1.06L8.94 8 6.22 5.28a.75.75 0 010-1.06z" clip-rule="evenodd" />
          </svg>
        </li>
        <li>
          <span class="font-medium text-navy-700 dark:text-stone-200" aria-current="page">{data.nomor}</span>
        </li>
      </ol>
    </nav>

    <div class="mt-6 flex flex-col gap-8 lg:flex-row">
      <!-- Main content -->
      <div class="min-w-0 flex-1">
        <header>
          <div class="flex flex-wrap items-center gap-2">
            <span class="bg-navy-100 px-2 py-0.5 font-mono text-xs font-medium text-navy-800 dark:bg-navy-800 dark:text-navy-200">
              {data.jenis}
            </span>
            <span class={`px-2 py-0.5 text-xs font-medium capitalize ${statusColors[data.status]}`}>
              {data.status}
            </span>
          </div>
          <h1 class="mt-3 font-heading text-2xl font-bold tracking-tight text-navy-800 dark:text-stone-100 sm:text-3xl">
            {data.nomor}
          </h1>
          <p class="mt-2 text-lg text-navy-600 dark:text-stone-300">{data.title}</p>
        </header>

        <!-- Metadata -->
        <dl class="mt-6 grid grid-cols-2 gap-4 border-y-2 border-navy-100 py-6 dark:border-navy-800 sm:grid-cols-3">
          <div>
            <dt class="text-xs font-medium tracking-wide text-navy-400 uppercase dark:text-stone-500">Diundangkan</dt>
            <dd class="mt-1 font-mono text-sm text-navy-700 dark:text-stone-300">{data.tanggal_diundangkan}</dd>
          </div>
          <div>
            <dt class="text-xs font-medium tracking-wide text-navy-400 uppercase dark:text-stone-500">Berlaku</dt>
            <dd class="mt-1 font-mono text-sm text-navy-700 dark:text-stone-300">{data.tanggal_berlaku}</dd>
          </div>
          <div>
            <dt class="text-xs font-medium tracking-wide text-navy-400 uppercase dark:text-stone-500">Tahun</dt>
            <dd class="mt-1 font-mono text-sm text-navy-700 dark:text-stone-300">{data.tahun}</dd>
          </div>
          {data.berlaku_untuk && data.berlaku_untuk.length > 0 && (
            <div class="col-span-2 sm:col-span-3">
              <dt class="text-xs font-medium tracking-wide text-navy-400 uppercase dark:text-stone-500">Berlaku Untuk</dt>
              <dd class="mt-1 flex flex-wrap gap-1.5">
                {data.berlaku_untuk.map((t: string) => (
                  <span class="bg-navy-50 px-2 py-0.5 font-mono text-xs text-navy-600 dark:bg-navy-800 dark:text-stone-400">{t}</span>
                ))}
              </dd>
            </div>
          )}
        </dl>

        <!-- Topics -->
        <div class="mt-4 flex flex-wrap gap-1.5">
          {data.topik.map((t: string) => (
            <span class="border border-navy-200 px-2 py-0.5 text-xs text-navy-500 dark:border-navy-700 dark:text-stone-400">
              {t}
            </span>
          ))}
        </div>

        <!-- Regulation Toolbar -->
        <div id="reg-toolbar" class="sticky top-0 z-40 -mx-4 mt-6 flex items-center gap-1 overflow-x-auto border-b border-navy-200 bg-white/95 px-4 py-2.5 backdrop-blur-sm sm:gap-2 dark:border-navy-700 dark:bg-navy-900/95">
          <button id="tb-search" type="button" class="tb-btn flex shrink-0 items-center gap-1.5 rounded-lg px-3 py-2 text-sm font-medium text-navy-600 transition-colors hover:bg-navy-100 dark:text-stone-300 dark:hover:bg-navy-800">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4"><path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" /></svg>
            <span class="hidden sm:inline">Cari Kata</span>
          </button>
          {data.lampiran_pdf ? (
            <a href={data.lampiran_pdf} target="_blank" rel="noopener noreferrer" class="tb-btn flex shrink-0 items-center gap-1.5 rounded-lg px-3 py-2 text-sm font-medium text-navy-600 transition-colors hover:bg-navy-100 dark:text-stone-300 dark:hover:bg-navy-800">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4"><path d="M4.5 2A1.5 1.5 0 003 3.5v13A1.5 1.5 0 004.5 18h11a1.5 1.5 0 001.5-1.5V7.621a1.5 1.5 0 00-.44-1.06l-4.12-4.122A1.5 1.5 0 0011.378 2H4.5z" /></svg>
              <span class="hidden sm:inline">Lampiran</span>
            </a>
          ) : (
            <button type="button" disabled class="tb-btn flex shrink-0 items-center gap-1.5 rounded-lg px-3 py-2 text-sm font-medium text-navy-300 dark:text-stone-600" title="Tidak ada lampiran">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4"><path d="M4.5 2A1.5 1.5 0 003 3.5v13A1.5 1.5 0 004.5 18h11a1.5 1.5 0 001.5-1.5V7.621a1.5 1.5 0 00-.44-1.06l-4.12-4.122A1.5 1.5 0 0011.378 2H4.5z" /></svg>
              <span class="hidden sm:inline">Lampiran</span>
            </button>
          )}
          <button id="tb-relasi" type="button" class="tb-btn flex shrink-0 items-center gap-1.5 rounded-lg px-3 py-2 text-sm font-medium text-navy-600 transition-colors hover:bg-navy-100 dark:text-stone-300 dark:hover:bg-navy-800">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4"><path fill-rule="evenodd" d="M4.25 2A2.25 2.25 0 002 4.25v2.5A2.25 2.25 0 004.25 9h2.5A2.25 2.25 0 009 6.75v-2.5A2.25 2.25 0 006.75 2h-2.5zm0 9A2.25 2.25 0 002 13.25v2.5A2.25 2.25 0 004.25 18h2.5A2.25 2.25 0 009 15.75v-2.5A2.25 2.25 0 006.75 11h-2.5zm9-9A2.25 2.25 0 0011 4.25v2.5A2.25 2.25 0 0013.25 9h2.5A2.25 2.25 0 0018 6.75v-2.5A2.25 2.25 0 0015.75 2h-2.5z" clip-rule="evenodd" /></svg>
            <span class="hidden sm:inline">Relasi</span>
          </button>
          {data.sumber_pdf ? (
            <a href={data.sumber_pdf} target="_blank" rel="noopener noreferrer" class="tb-btn flex shrink-0 items-center gap-1.5 rounded-lg px-3 py-2 text-sm font-medium text-navy-600 transition-colors hover:bg-navy-100 dark:text-stone-300 dark:hover:bg-navy-800">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4"><path d="M10.75 2.75a.75.75 0 00-1.5 0v8.614L6.295 8.235a.75.75 0 10-1.09 1.03l4.25 4.5a.75.75 0 001.09 0l4.25-4.5a.75.75 0 00-1.09-1.03l-2.955 3.129V2.75z" /><path d="M3.5 12.75a.75.75 0 00-1.5 0v2.5A2.75 2.75 0 004.75 18h10.5A2.75 2.75 0 0018 15.25v-2.5a.75.75 0 00-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H4.75c-.69 0-1.25-.56-1.25-1.25v-2.5z" /></svg>
              <span class="hidden sm:inline">Download</span>
            </a>
          ) : (
            <button type="button" disabled class="tb-btn flex shrink-0 items-center gap-1.5 rounded-lg px-3 py-2 text-sm font-medium text-navy-300 dark:text-stone-600" title="PDF tidak tersedia">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4"><path d="M10.75 2.75a.75.75 0 00-1.5 0v8.614L6.295 8.235a.75.75 0 10-1.09 1.03l4.25 4.5a.75.75 0 001.09 0l4.25-4.5a.75.75 0 00-1.09-1.03l-2.955 3.129V2.75z" /></svg>
              <span class="hidden sm:inline">Download</span>
            </button>
          )}
          <button id="tb-copy" type="button" class="tb-btn flex shrink-0 items-center gap-1.5 rounded-lg px-3 py-2 text-sm font-medium text-navy-600 transition-colors hover:bg-navy-100 dark:text-stone-300 dark:hover:bg-navy-800">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4"><path d="M12.232 4.232a2.5 2.5 0 013.536 3.536l-1.225 1.224a.75.75 0 001.061 1.06l1.224-1.224a4 4 0 00-5.656-5.656l-3 3a4 4 0 00.225 5.865.75.75 0 00.977-1.138 2.5 2.5 0 01-.142-3.667l3-3z" /><path d="M11.603 7.963a.75.75 0 00-.977 1.138 2.5 2.5 0 01.142 3.667l-3 3a2.5 2.5 0 01-3.536-3.536l1.225-1.224a.75.75 0 00-1.061-1.06l-1.224 1.224a4 4 0 105.656 5.656l3-3a4 4 0 00-.225-5.865z" /></svg>
            <span class="hidden sm:inline">Salin Link</span>
          </button>
        </div>

        <!-- Search Bar (hidden by default, toggled by Cari Kata) -->
        <div id="search-bar" class="hidden -mx-4 flex items-center gap-2 border-b border-navy-200 bg-navy-50 px-4 py-3 dark:border-navy-700 dark:bg-navy-800">
          <input id="search-input" type="text" placeholder="Cari kata di peraturan ini..." class="flex-1 border border-navy-200 bg-white px-3 py-1.5 text-sm text-navy-800 placeholder:text-navy-400 focus:border-gold-400 focus:outline-none dark:border-navy-700 dark:bg-navy-900 dark:text-stone-100 dark:placeholder:text-stone-500" />
          <span id="search-count" class="shrink-0 text-xs text-navy-400 dark:text-stone-500">0/0</span>
          <button id="search-prev" type="button" class="rounded p-1 text-navy-500 hover:bg-navy-200 dark:text-stone-400 dark:hover:bg-navy-700" aria-label="Sebelumnya">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4"><path fill-rule="evenodd" d="M11.78 9.78a.75.75 0 01-1.06 0L8 7.06 5.28 9.78a.75.75 0 01-1.06-1.06l3.25-3.25a.75.75 0 011.06 0l3.25 3.25a.75.75 0 010 1.06z" clip-rule="evenodd" /></svg>
          </button>
          <button id="search-next" type="button" class="rounded p-1 text-navy-500 hover:bg-navy-200 dark:text-stone-400 dark:hover:bg-navy-700" aria-label="Berikutnya">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4"><path fill-rule="evenodd" d="M4.22 6.22a.75.75 0 011.06 0L8 8.94l2.72-2.72a.75.75 0 111.06 1.06l-3.25 3.25a.75.75 0 01-1.06 0L4.22 7.28a.75.75 0 010-1.06z" clip-rule="evenodd" /></svg>
          </button>
          <button id="search-close" type="button" class="rounded p-1 text-navy-500 hover:bg-navy-200 dark:text-stone-400 dark:hover:bg-navy-700" aria-label="Tutup">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4"><path d="M5.28 4.22a.75.75 0 00-1.06 1.06L6.94 8l-2.72 2.72a.75.75 0 101.06 1.06L8 9.06l2.72 2.72a.75.75 0 101.06-1.06L9.06 8l2.72-2.72a.75.75 0 00-1.06-1.06L8 6.94 5.28 4.22z" /></svg>
          </button>
        </div>

        <!-- Relasi Panel (hidden by default, toggled by Relasi button) -->
        <div id="relasi-panel" class="hidden -mx-4 border-b border-navy-200 bg-white px-4 py-4 shadow-lg dark:border-navy-700 dark:bg-navy-800">
          <div class="grid gap-4 sm:grid-cols-3">
            <div>
              <h4 class="mb-2 text-xs font-semibold tracking-wide text-navy-400 uppercase dark:text-stone-500">Status</h4>
              <div class="flex items-center gap-2">
                <span class={`px-2 py-0.5 text-xs font-medium capitalize ${statusColors[data.status]}`}>{data.status}</span>
                <span class="text-sm text-navy-500 dark:text-stone-400">sejak {data.tanggal_berlaku}</span>
              </div>
            </div>
            <div>
              <h4 class="mb-2 text-xs font-semibold tracking-wide text-navy-400 uppercase dark:text-stone-500">Riwayat</h4>
              <div class="space-y-1 text-sm">
                {data.mencabut && data.mencabut.length > 0 ? (
                  <p class="text-navy-600 dark:text-stone-300">Mencabut: {data.mencabut.map((n: string) => {
                    const r = relatedMap.get(n);
                    return r ? <a href={`/perpustakaan/${r.id}`} class="text-gold-600 hover:underline dark:text-gold-400">{n}</a> : <span>{n}</span>;
                  })}</p>
                ) : null}
                {data.dicabut_oleh ? (
                  <p class="text-navy-600 dark:text-stone-300">Dicabut oleh: {(() => {
                    const r = relatedMap.get(data.dicabut_oleh);
                    return r ? <a href={`/perpustakaan/${r.id}`} class="text-gold-600 hover:underline dark:text-gold-400">{data.dicabut_oleh}</a> : <span>{data.dicabut_oleh}</span>;
                  })()}</p>
                ) : null}
                {data.mengubah ? (
                  <p class="text-navy-600 dark:text-stone-300">Mengubah: {(() => {
                    const r = relatedMap.get(data.mengubah);
                    return r ? <a href={`/perpustakaan/${r.id}`} class="text-gold-600 hover:underline dark:text-gold-400">{data.mengubah}</a> : <span>{data.mengubah}</span>;
                  })()}</p>
                ) : null}
                {data.diubah_oleh && data.diubah_oleh.length > 0 ? (
                  <p class="text-navy-600 dark:text-stone-300">Diubah oleh: {data.diubah_oleh.map((n: string) => {
                    const r = relatedMap.get(n);
                    return r ? <a href={`/perpustakaan/${r.id}`} class="text-gold-600 hover:underline dark:text-gold-400">{n}</a> : <span>{n}</span>;
                  })}</p>
                ) : null}
                {!data.mencabut?.length && !data.dicabut_oleh && !data.mengubah && !data.diubah_oleh?.length && (
                  <p class="text-navy-400 dark:text-stone-500">Tidak ada riwayat perubahan</p>
                )}
              </div>
            </div>
            <div>
              <h4 class="mb-2 text-xs font-semibold tracking-wide text-navy-400 uppercase dark:text-stone-500">Dasar Hukum</h4>
              {data.dasar_hukum ? (
                <p class="text-sm text-navy-600 dark:text-stone-300">{(() => {
                  const r = relatedMap.get(data.dasar_hukum);
                  return r ? <a href={`/perpustakaan/${r.id}`} class="text-gold-600 hover:underline dark:text-gold-400">{data.dasar_hukum}</a> : <span>{data.dasar_hukum}</span>;
                })()}</p>
              ) : (
                <p class="text-sm text-navy-400 dark:text-stone-500">—</p>
              )}
            </div>
          </div>
        </div>

        <!-- Table of Contents (auto-generated from BAB/Pasal headings) -->
        <nav id="toc-container" class="mt-6 hidden border-2 border-navy-100 dark:border-navy-800" aria-label="Daftar isi peraturan">
          <button
            id="toc-toggle"
            type="button"
            class="flex w-full items-center justify-between px-5 py-3 text-left font-heading text-sm font-semibold tracking-wide text-navy-800 uppercase dark:text-stone-100"
            aria-expanded="true"
            aria-controls="toc-list"
          >
            Daftar Isi
            <svg id="toc-chevron" class="h-5 w-5 shrink-0 text-navy-400 transition-transform dark:text-stone-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 011.06 0L10 11.94l3.72-3.72a.75.75 0 111.06 1.06l-4.25 4.25a.75.75 0 01-1.06 0L5.22 9.28a.75.75 0 010-1.06z" clip-rule="evenodd" />
            </svg>
          </button>
          <ol id="toc-list" class="space-y-1 px-5 pb-4 text-sm"></ol>
        </nav>

        <!-- Body content -->
        <div id="legal-content" class="legal-prose prose prose-navy mt-8 dark:prose-invert prose-headings:font-heading prose-headings:tracking-tight prose-a:text-gold-600 prose-a:no-underline hover:prose-a:underline" data-pagefind-body data-crossref={JSON.stringify(crossRefMap)}>
          <span data-pagefind-meta={`keywords[${searchKeywords}]`} style="display:none;"></span>
          <Content />
        </div>

        {(data.sumber_pdf || data.lampiran_pdf) && (
          <div class="mt-8 flex flex-wrap gap-4 border-t-2 border-navy-100 pt-6 dark:border-navy-800">
            {data.lampiran_pdf && (
              <a
                href={data.lampiran_pdf}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 border-2 border-gold-400 bg-gold-400/10 px-5 py-2.5 font-heading text-sm font-semibold text-gold-700 transition-colors hover:bg-gold-400 hover:text-navy-900 dark:text-gold-400 dark:hover:bg-gold-400 dark:hover:text-navy-900"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                  <path d="M4.5 2A1.5 1.5 0 003 3.5v13A1.5 1.5 0 004.5 18h11a1.5 1.5 0 001.5-1.5V7.621a1.5 1.5 0 00-.44-1.06l-4.12-4.122A1.5 1.5 0 0011.378 2H4.5zm4.75 11.25a.75.75 0 01-1.5 0V8.636L6.295 10.09a.75.75 0 01-1.09-1.03l3.25-3.5a.75.75 0 011.09 0l3.25 3.5a.75.75 0 11-1.09 1.03L10.25 8.636v4.614z" />
                </svg>
                Lihat Lampiran PDF
              </a>
            )}
            {data.sumber_pdf && (
              <a
                href={data.sumber_pdf}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-sm font-medium text-gold-600 hover:text-gold-500 dark:text-gold-400 dark:hover:text-gold-300"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                  <path d="M10.75 2.75a.75.75 0 00-1.5 0v8.614L6.295 8.235a.75.75 0 10-1.09 1.03l4.25 4.5a.75.75 0 001.09 0l4.25-4.5a.75.75 0 00-1.09-1.03l-2.955 3.129V2.75z" />
                  <path d="M3.5 12.75a.75.75 0 00-1.5 0v2.5A2.75 2.75 0 004.75 18h10.5A2.75 2.75 0 0018 15.25v-2.5a.75.75 0 00-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H4.75c-.69 0-1.25-.56-1.25-1.25v-2.5z" />
                </svg>
                Download PDF Asli
              </a>
            )}
          </div>
        )}
      </div>

      <!-- Sidebar -->
      {relations.length > 0 && (
        <aside class="w-full shrink-0 lg:w-72">
          <div class="sticky top-20 border-2 border-navy-100 p-5 dark:border-navy-800">
            <h2 class="font-heading text-sm font-semibold tracking-widest text-navy-800 uppercase dark:text-stone-100">
              Peraturan Terkait
            </h2>
            <div class="mt-4 space-y-4">
              {relations.map(({ label, items }) => (
                <div>
                  <p class="text-xs font-medium tracking-wide text-navy-400 uppercase dark:text-stone-500">{label}</p>
                  <ul class="mt-1.5 space-y-1">
                    {items.map((nomor) => {
                      const related = relatedMap.get(nomor);
                      return (
                        <li>
                          {related ? (
                            <a
                              href={`/perpustakaan/${related.id}`}
                              class="block text-sm font-medium text-gold-600 hover:text-gold-500 dark:text-gold-400 dark:hover:text-gold-300"
                            >
                              {nomor}
                            </a>
                          ) : (
                            <span class="block font-mono text-sm text-navy-500 dark:text-stone-400">{nomor}</span>
                          )}
                        </li>
                      );
                    })}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </aside>
      )}
    </div>
  </article>

  <script is:inline>
    // Format legal document keywords in rendered content
    document.addEventListener('DOMContentLoaded', () => {
      const container = document.getElementById('legal-content');
      if (!container) return;

      const paragraphs = container.querySelectorAll('p');
      paragraphs.forEach((p) => {
        const text = p.textContent?.trim() || '';

        // BAB headings (e.g., "BAB I", "BAB II", "BAB XIV")
        if (/^BAB\s+[IVXLCDM\d]+$/i.test(text)) {
          p.classList.add('legal-bab');
          // Next sibling might be the BAB title
          const next = p.nextElementSibling;
          if (next && next.tagName === 'P') {
            const nextText = next.textContent?.trim() || '';
            if (nextText.length < 100 && nextText === nextText.toUpperCase()) {
              next.classList.add('legal-bab-title');
            }
          }
          return;
        }

        // Bagian headings
        if (/^Bagian\s+(Ke(satu|dua|tiga|empat|lima|enam|tujuh|delapan|sembilan|sepuluh)|Pertama)/i.test(text)) {
          p.classList.add('legal-bagian');
          const next = p.nextElementSibling;
          if (next && next.tagName === 'P') {
            const nextText = next.textContent?.trim() || '';
            if (nextText.length < 100) {
              next.classList.add('legal-bagian');
            }
          }
          return;
        }

        // Pasal headings (e.g., "Pasal 1", "Pasal 23")
        if (/^Pasal\s+\d+[A-Z]?$/i.test(text)) {
          p.classList.add('legal-pasal');
          return;
        }

        // MEMUTUSKAN:
        if (/^MEMUTUSKAN\s*:?$/i.test(text)) {
          p.classList.add('legal-memutuskan');
          return;
        }

        // Menimbang, Mengingat, Menetapkan
        if (/^(Menimbang|Mengingat|Menetapkan)\s/i.test(text)) {
          p.classList.add('legal-keyword');
          return;
        }

        // Indent ayat-level content: (1), (2), etc.
        if (/^\(\d+\)/.test(text)) {
          p.classList.add('legal-indent-1');
          return;
        }

        // Indent letter-level content: a., b., c., etc.
        if (/^[a-z]\.\s/.test(text)) {
          p.classList.add('legal-indent-2');
          return;
        }
      });

      // Generate Table of Contents + Anchor IDs from BAB/Pasal headings
      // Supports both Ortax HTML (<div><strong>BAB I</strong></div>) and legacy (<p>BAB I</p>)
      (function() {
        var tocContainer = document.getElementById('toc-container');
        var tocList = document.getElementById('toc-list');
        var tocToggle = document.getElementById('toc-toggle');
        var tocChevron = document.getElementById('toc-chevron');
        if (!tocContainer || !tocList || !container) return;

        var entries = [];

        // Scan ALL <strong> elements inside legal-content for BAB/Pasal patterns
        var strongs = container.querySelectorAll('strong');
        strongs.forEach(function(strong) {
          var text = strong.textContent?.trim() || '';
          var type = null;
          var id = null;
          var label = text;

          // Match BAB headings: "BAB I", "BAB II", "BAB XIV"
          var babMatch = text.match(/^BAB\s+([IVXLCDM\d]+)\s*$/i);
          if (babMatch) {
            type = 'bab';
            id = 'BAB_' + babMatch[1];
            // Check if next <strong> sibling has the BAB title
            var parent = strong.closest('div') || strong.parentElement;
            if (parent) {
              var allStrongs = parent.querySelectorAll('strong');
              for (var i = 0; i < allStrongs.length; i++) {
                if (allStrongs[i] === strong && i + 1 < allStrongs.length) {
                  var nextText = allStrongs[i+1].textContent?.trim() || '';
                  // BAB title is usually UPPERCASE and short
                  if (nextText.length < 150 && !/^BAB\s|^Pasal\s/i.test(nextText)) {
                    label = text + ' — ' + nextText;
                  }
                  break;
                }
              }
            }
          }

          // Match Pasal headings: "Pasal 1", "Pasal 23", "Pasal 5A"
          var pasalMatch = text.match(/^Pasal\s+(\d+[A-Z]?)\s*$/i);
          if (pasalMatch) {
            type = 'pasal';
            id = 'Pasal_' + pasalMatch[1];
          }

          if (type && id) {
            // Add anchor ID — if parent already has an id, wrap with a span instead
            var anchor = strong.closest('div[style*="center"]') || strong.closest('p') || strong.parentElement;
            if (anchor && !anchor.id) {
              anchor.id = id;
            } else {
              // Parent already has id (e.g., BAB div also contains Pasal) — set id on <strong> itself
              strong.id = id;
            }
            // Avoid duplicates
            if (!entries.some(function(e) { return e.id === id; })) {
              entries.push({ id: id, label: label, type: type });
            }
          }
        });

        // Fallback: also check <p> tags for legacy non-Ortax content
        if (entries.length === 0) {
          paragraphs.forEach(function(p) {
            var text = p.textContent?.trim() || '';
            if (/^BAB\s+[IVXLCDM\d]+$/i.test(text)) {
              var babId = 'BAB_' + text.replace(/^BAB\s+/i, '');
              p.id = babId;
              entries.push({ id: babId, label: text, type: 'bab' });
            } else if (/^Pasal\s+\d+[A-Z]?$/i.test(text)) {
              var pasalId = 'Pasal_' + text.replace(/^Pasal\s+/i, '');
              p.id = pasalId;
              entries.push({ id: pasalId, label: text, type: 'pasal' });
            }
          });
        }

        if (entries.length < 2) return; // Don't show TOC for short docs

        tocContainer.classList.remove('hidden');

        entries.forEach(function(entry) {
          var li = document.createElement('li');
          li.className = entry.type === 'pasal' ? 'pl-4' : '';
          var a = document.createElement('a');
          a.href = '#' + entry.id;
          a.textContent = entry.label;
          a.className = entry.type === 'bab'
            ? 'block py-1 font-semibold text-navy-700 hover:text-gold-600 dark:text-stone-200 dark:hover:text-gold-400'
            : 'block py-0.5 text-navy-500 hover:text-gold-600 dark:text-stone-400 dark:hover:text-gold-400';
          a.addEventListener('click', function(e) {
            e.preventDefault();
            var target = document.getElementById(entry.id);
            if (target) {
              var top = target.getBoundingClientRect().top + window.scrollY - 80;
              window.scrollTo({ top: top, behavior: 'instant' });
              history.pushState(null, '', '#' + entry.id);
            }
          });
          li.appendChild(a);
          tocList.appendChild(li);
        });

        // Toggle collapse
        var isOpen = true;
        tocToggle?.addEventListener('click', function() {
          isOpen = !isOpen;
          tocList.style.display = isOpen ? '' : 'none';
          tocToggle.setAttribute('aria-expanded', isOpen.toString());
          tocChevron.style.transform = isOpen ? '' : 'rotate(-90deg)';
        });
      })();

      // Cross-reference: auto-link regulation numbers in body text
      (function() {
        var crossRefData = container.getAttribute('data-crossref');
        if (!crossRefData) return;
        var crossRef;
        try { crossRef = JSON.parse(crossRefData); } catch(e) { return; }

        // Get current page URL to avoid self-linking
        var currentPath = window.location.pathname;

        // Walk text nodes inside <td> and <li> elements (where body text lives)
        var textContainers = container.querySelectorAll('td, li, p');
        textContainers.forEach(function(el) {
          // Skip if element already contains links (avoid double-linking)
          if (el.querySelector('a')) return;
          // Skip centered elements (these are headings, not body text)
          if (el.closest('[style*="text-align: center"]') || el.closest('[style*="text-align:center"]')) return;

          var html = el.innerHTML;
          var changed = false;

          // For each known regulation number, check if it appears in text
          Object.keys(crossRef).forEach(function(nomor) {
            var url = crossRef[nomor];
            if (url === currentPath) return; // Don't self-link

            // Escape special regex chars in nomor
            var escaped = nomor.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
            // Only match if not already inside an <a> tag
            var regex = new RegExp('(?<!<a[^>]*>)(' + escaped + ')(?![^<]*</a>)', 'g');

            if (regex.test(html)) {
              html = html.replace(regex, '<a href="' + url + '" class="text-gold-600 hover:underline dark:text-gold-400">$1</a>');
              changed = true;
            }
          });

          if (changed) {
            el.innerHTML = html;
          }
        });

        // Clean up data attribute (not needed after processing)
        container.removeAttribute('data-crossref');
      })();

      // Handle initial page load with hash (deep link) — retry until accurate
      if (window.location.hash) {
        var deepLinkId = window.location.hash.slice(1);
        var dlAttempts = 0;
        function tryDeepLink() {
          var el = document.getElementById(deepLinkId);
          if (el) {
            var top = el.getBoundingClientRect().top + window.scrollY - 80;
            window.scrollTo({ top: top, behavior: 'instant' });
            // Verify position after render tick
            requestAnimationFrame(function() {
              var rect = el.getBoundingClientRect();
              if (Math.abs(rect.top - 80) > 150 && dlAttempts < 8) {
                dlAttempts++;
                setTimeout(tryDeepLink, 250);
              }
            });
          } else if (dlAttempts < 8) {
            dlAttempts++;
            setTimeout(tryDeepLink, 300);
          }
        }
        requestAnimationFrame(function() { setTimeout(tryDeepLink, 300); });
      }
    });

    // Handle hashchange event (back/forward navigation)
    window.addEventListener('hashchange', function() {
      var targetId = window.location.hash.slice(1);
      var el = document.getElementById(targetId);
      if (el) {
        var top = el.getBoundingClientRect().top + window.scrollY - 80;
        window.scrollTo({ top: top, behavior: 'instant' });
      }
    });

    // === TOOLBAR INTERACTIONS ===

    // Toggle Relasi panel
    (function() {
      var btn = document.getElementById('tb-relasi');
      var panel = document.getElementById('relasi-panel');
      if (!btn || !panel) return;
      btn.addEventListener('click', function() {
        var isOpen = !panel.classList.contains('hidden');
        panel.classList.toggle('hidden');
        btn.classList.toggle('bg-gold-100', !isOpen);
        btn.classList.toggle('text-gold-700', !isOpen);
        btn.classList.toggle('dark:bg-gold-900/30', !isOpen);
        btn.classList.toggle('dark:text-gold-400', !isOpen);
        // Close search bar if open
        document.getElementById('search-bar')?.classList.add('hidden');
      });
    })();

    // Copy Link
    (function() {
      var btn = document.getElementById('tb-copy');
      if (!btn) return;
      btn.addEventListener('click', function() {
        navigator.clipboard.writeText(window.location.href).then(function() {
          var toast = document.createElement('div');
          toast.textContent = 'Link berhasil disalin!';
          toast.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 z-50 rounded-lg bg-navy-800 px-4 py-2 text-sm font-medium text-white shadow-lg dark:bg-gold-400 dark:text-navy-900';
          document.body.appendChild(toast);
          setTimeout(function() { toast.remove(); }, 2000);
        });
      });
    })();

    // In-Page Search (Cari Kata)
    (function() {
      var btn = document.getElementById('tb-search');
      var bar = document.getElementById('search-bar');
      var input = document.getElementById('search-input');
      var countEl = document.getElementById('search-count');
      var prevBtn = document.getElementById('search-prev');
      var nextBtn = document.getElementById('search-next');
      var closeBtn = document.getElementById('search-close');
      var content = document.getElementById('legal-content');
      if (!btn || !bar || !input || !content) return;

      var marks = [];
      var currentIdx = -1;

      function clearHighlights() {
        marks.forEach(function(m) {
          var parent = m.parentNode;
          parent.replaceChild(document.createTextNode(m.textContent), m);
          parent.normalize();
        });
        marks = [];
        currentIdx = -1;
        if (countEl) countEl.textContent = '0/0';
      }

      function highlightMatches(query) {
        clearHighlights();
        if (query.length < 2) return;

        var walker = document.createTreeWalker(content, NodeFilter.SHOW_TEXT, null);
        var textNodes = [];
        while (walker.nextNode()) textNodes.push(walker.currentNode);

        var lowerQuery = query.toLowerCase();
        textNodes.forEach(function(node) {
          var text = node.textContent;
          var lower = text.toLowerCase();
          var idx = lower.indexOf(lowerQuery);
          if (idx === -1) return;

          var frag = document.createDocumentFragment();
          var lastIdx = 0;
          while (idx !== -1) {
            frag.appendChild(document.createTextNode(text.substring(lastIdx, idx)));
            var mark = document.createElement('mark');
            mark.className = 'bg-yellow-200 dark:bg-yellow-700/50';
            mark.textContent = text.substring(idx, idx + query.length);
            frag.appendChild(mark);
            marks.push(mark);
            lastIdx = idx + query.length;
            idx = lower.indexOf(lowerQuery, lastIdx);
          }
          frag.appendChild(document.createTextNode(text.substring(lastIdx)));
          node.parentNode.replaceChild(frag, node);
        });

        if (marks.length > 0) {
          currentIdx = 0;
          goToMatch(0);
        }
        if (countEl) countEl.textContent = marks.length > 0 ? '1/' + marks.length : '0/0';
      }

      function goToMatch(idx) {
        if (marks.length === 0) return;
        // Remove active highlight from previous
        if (currentIdx >= 0 && currentIdx < marks.length) {
          marks[currentIdx].className = 'bg-yellow-200 dark:bg-yellow-700/50';
        }
        currentIdx = ((idx % marks.length) + marks.length) % marks.length;
        var m = marks[currentIdx];
        m.className = 'bg-yellow-400 ring-2 ring-gold-500 dark:bg-yellow-500/70';
        var top = m.getBoundingClientRect().top + window.scrollY - 120;
        window.scrollTo({ top: top, behavior: 'instant' });
        if (countEl) countEl.textContent = (currentIdx + 1) + '/' + marks.length;
      }

      btn.addEventListener('click', function() {
        var isOpen = !bar.classList.contains('hidden');
        bar.classList.toggle('hidden');
        btn.classList.toggle('bg-gold-100', !isOpen);
        btn.classList.toggle('text-gold-700', !isOpen);
        if (!isOpen) {
          input.focus();
        } else {
          clearHighlights();
          input.value = '';
        }
        // Close relasi if open
        document.getElementById('relasi-panel')?.classList.add('hidden');
      });

      var debounce;
      input.addEventListener('input', function() {
        clearTimeout(debounce);
        debounce = setTimeout(function() { highlightMatches(input.value.trim()); }, 200);
      });

      prevBtn?.addEventListener('click', function() { goToMatch(currentIdx - 1); });
      nextBtn?.addEventListener('click', function() { goToMatch(currentIdx + 1); });
      closeBtn?.addEventListener('click', function() {
        bar.classList.add('hidden');
        btn.classList.remove('bg-gold-100', 'text-gold-700');
        clearHighlights();
        input.value = '';
      });

      // Keyboard: Escape to close, Enter for next match
      input.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') { closeBtn?.click(); }
        if (e.key === 'Enter') { e.shiftKey ? goToMatch(currentIdx - 1) : goToMatch(currentIdx + 1); }
      });
    })();
  </script>
</BaseLayout>
